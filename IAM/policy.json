{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "VisualEditor0",
			"Effect": "Allow",
			"Action": [
				"s3:PutObject",
				"s3:CreateBucket"
			],
			"Resource": "arn:aws:s3:::*"
		},
		{
			"Sid": "VisualEditor1",
			"Effect": "Allow",
			"Action": [
				"s3:CreateAccessPoint",
				"s3:PutObject",
				"s3:CreateBucket"
			],
			"Resource": "*"
		},
		{
			"Sid": "VisualEditor2",
			"Effect": "Deny",
			"Action": [
				"s3:DeleteAccessPoint",
				"s3:DeleteObject"
			],
			"Resource": "arn:aws:s3:*:029180756899:accesspoint/*"
		}
	]
}